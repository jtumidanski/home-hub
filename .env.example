# Database
DB_HOST=postgres.home
DB_PORT=5432
DB_USER=home_hub
DB_PASSWORD=changeme
DB_NAME=home_hub

# Server
PORT=8080

# JWT (RSA private key in PEM format, single line with \n escapes)
JWT_PRIVATE_KEY=
JWT_KEY_ID=home-hub-1

# OIDC (Google)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=https://accounts.google.com

# Auth (used by all services except auth-service)
JWKS_URL=http://auth-service:8080/api/v1/auth/.well-known/jwks.json

# Weather Service
REFRESH_INTERVAL_MINUTES=15
CACHE_TTL_MINUTES=15
