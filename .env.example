# Database
DB_HOST=postgres.home
DB_PORT=5432
DB_USER=home_hub
DB_PASSWORD=changeme
DB_NAME=home_hub

# Server
PORT=8080

# JWT (RSA private key in PEM format, single line with \n escapes)
JWT_PRIVATE_KEY=
JWT_KEY_ID=home-hub-1

# OIDC (Google)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=https://accounts.google.com

# Auth (used by all services except auth-service)
JWKS_URL=http://auth-service:8080/api/v1/auth/.well-known/jwks.json

# Weather Service
REFRESH_INTERVAL_MINUTES=15
CACHE_TTL_MINUTES=15

# Calendar Service
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# 32-byte AES-256 key, base64 encoded. Generate with: openssl rand -base64 32
CALENDAR_TOKEN_ENCRYPTION_KEY=
SYNC_INTERVAL_MINUTES=15

# Package Service
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
# Set to "true" if using FedEx sandbox credentials
FEDEX_SANDBOX=false
# 32-byte AES-256 key, base64 encoded. Generate with: openssl rand -base64 32
PACKAGE_TOKEN_ENCRYPTION_KEY=
PACKAGE_POLL_INTERVAL_MINUTES=30
PACKAGE_MAX_ACTIVE_PER_HOUSEHOLD=25
