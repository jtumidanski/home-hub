# Home Hub Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Optional: Database name (service-specific databases are created automatically)
# DB_NAME=home_hub

# ==========================================
# Google OAuth Configuration
# ==========================================
# Create a Google OAuth app: See docs/auth-setup-google.md
# Get these values from: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=123456789-abc123def456ghi789.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret_here

# Generate with: python -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
GOOGLE_COOKIE_SECRET=your_32_byte_base64_encoded_secret_here

# Optional: Restrict to specific email domain (leave empty or set to * for any domain)
# GOOGLE_EMAIL_DOMAIN=yourdomain.com

# ==========================================
# GitHub OAuth Configuration
# ==========================================
# Create a GitHub OAuth app: See docs/auth-setup-github.md
# Get these values from: https://github.com/settings/developers

GITHUB_CLIENT_ID=Iv1.your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Generate with: python -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
# IMPORTANT: Use a DIFFERENT secret than Google
GITHUB_COOKIE_SECRET=your_32_byte_base64_encoded_secret_here

# Optional: Restrict to specific GitHub organization
# GITHUB_ORG=your-github-org

# ==========================================
# Authentication General Settings
# ==========================================

# Domain for cookies (should match your deployment)
# Local: homehub.localtest.me
# Production: homehub.example.com
COOKIE_DOMAIN=homehub.localtest.me

# Cookie security settings
# Set to true in production (HTTPS required), false for local HTTP
COOKIE_SECURE=false

# Cookie expiration (in hours)
# Default: 168h (7 days)
COOKIE_EXPIRE=168h

# Cookie refresh interval (in hours)
# Default: 1h
COOKIE_REFRESH=1h

# ==========================================
# Application URLs
# ==========================================

# Base URL for the application
# Local: http://homehub.localtest.me
# Production: https://homehub.example.com
APP_BASE_URL=http://homehub.localtest.me

# Internal service URLs (for docker-compose)
NGINX_PORT=3000
OAUTH2_PROXY_GOOGLE_PORT=4180
OAUTH2_PROXY_GITHUB_PORT=4181
SVC_USERS_PORT=8081
ADMIN_PORT=5174
KIOSK_PORT=5173

# ==========================================
# Service JWT Configuration (Future)
# ==========================================
# Used by gateway to sign service-to-service JWTs
# Generate with: python -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
# SERVICE_JWT_SECRET=your_jwt_secret_here

# ==========================================
# PgAdmin Configuration (Optional)
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ==========================================
# Development Settings
# ==========================================

# Environment (development, staging, production)
APP_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ==========================================
# Kubernetes Deployment (Production)
# ==========================================
# These are used in k8s manifests, not in docker-compose

# Namespace for deployment
# K8S_NAMESPACE=home-hub

# Image registry
# IMAGE_REGISTRY=ghcr.io/your-org

# Image tag
# IMAGE_TAG=latest

# TLS certificate (managed by cert-manager)
# TLS_SECRET_NAME=home-hub-tls

# Ingress class
# INGRESS_CLASS=nginx

# ==========================================
# Bootstrap Admin (Optional)
# ==========================================
# Email of the first admin user (auto-granted admin role on first login)
# BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com

# ==========================================
# Notes
# ==========================================
# 1. Never commit the actual .env file to git
# 2. Generate new secrets for each environment (dev, staging, prod)
# 3. Use different cookie secrets for Google and GitHub
# 4. In production, always set COOKIE_SECURE=true
# 5. Keep secrets secure and rotate them regularly (every 90 days recommended)
# 6. For Kubernetes, use Kubernetes Secrets instead of .env files
#
# Setup Guides:
# - Google OAuth: docs/auth-setup-google.md
# - GitHub OAuth: docs/auth-setup-github.md
# - Full setup: deploy/README.md
